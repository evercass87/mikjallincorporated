<!DOCTYPE html>
<html>
<head>
    <title>Mikjáll Inc. | Global Sovereign Infrastructure</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;400;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app">
        <header>
            <div class="logo">MIKJÁLL <span style="opacity:0.2">INC.</span></div>
            <div style="font-size:10px; color:#222; letter-spacing:3px">ESTABLISHED 2026 // HOLDING</div>
        </header>
        <main class="main-view">
            <aside class="side">
                <div class="widget">
                    <p class="label">Hold_Divisions</p>
                    <div class="item"><span>AMERICAN DOG SEC</span><b>ACTIVE</b></div>
                    <div class="item"><span>WIFEMARKED MEDIA</span><b>VAULTED</b></div>
                    <div class="item"><span>MIKJALL SPORTS</span><b>OPTIMIZED</b></div>
                    <div class="item"><span>MIKJALL MUSIC</span><b>STABLE</b></div>
                </div>
                <div class="widget">
                    <p class="label">Cyber_Arsenal</p>
                    <div class="item"><span>SCRAPER_ENGINE</span><b>V.4.2</b></div>
                    <div class="item"><span>ENCRYPTION</span><b>RSA-4096</b></div>
                </div>
            </aside>
            <section class="viewport">
                <p style="font-size:10px; letter-spacing:10px; color:#222; margin-bottom:30px">SVR_UNIT_01 // ACCESS_LEVEL_5</p>
                <h1 class="hero-h1"><%= t.title %></h1>
                <p class="hero-p">Engenharia ofensiva, inteligência de dados e custódia soberana de ativos de alto valor sob protocolos de segurança de nível estatal.</p>
                <button class="btn-elite"><%= t.vault %></button>
                <div class="terminal">
                    <p style="color:#222; margin-bottom:15px">// LIVE_CORE_FEED</p>
                    <% logs.forEach(log => { %><p style="opacity:0.6">> <%= log %></p><% }) %>
                    <p style="color:#fff">> SYSTEM_STATUS: OPERATIONAL_SUCCESS</p>
                </div>
            </section>
            <aside class="side">
                <div class="widget">
                    <p class="label">Telemetry</p>
                    <div class="item"><span>NODE_LOC</span><b>PORTO_ALEGRE</b></div>
                    <div class="item"><span>SYS_LOAD</span><b>14.2%</b></div>
                </div>
                <div class="widget">
                    <p class="label">Capital_Flow</p>
                    <div class="item"><span>BITCOIN</span><b>SYNCED</b></div>
                    <div class="item"><span>MONERO</span><b>ANON</b></div>
                </div>
            </aside>
        </main>
        <footer>
            <span>AMERICAN DOG SEC</span><span>WIFEMARKED</span><span>MIKJALL SPORTS</span><span>MIKJALL MUSIC</span>
        </footer>
    </div>
</body>
</html>